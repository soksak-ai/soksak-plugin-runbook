{
  "spec": "soksak-plugin-spec@1",
  "id": "soksak-plugin-runbook",
  "name": {
    "ko": "런북",
    "en": "Runbook"
  },
  "version": "0.1.0",
  "repo": "https://github.com/soksak-ai/soksak-plugin-runbook.git",
  "description": {
    "ko": "재사용 가능한 작업(런북)을 저장하고 실행한다. 작업은 파라미터·환경변수·시크릿·다른 작업 출력을 Reference 로 엮으며, 링킹은 순수 해석 + 의존 그래프 + 순환 검출로 안전하게 풀린다.",
    "en": "Store and run reusable commands (runbooks). Commands reference parameters, env vars, secrets, and other command outputs; linking resolves safely via pure evaluation, dependency graph, and cycle detection."
  },
  "entry": "main.js",
  "permissions": [
    "data",
    "commands",
    "commands:inject",
    "ui",
    "process",
    "network",
    "notify",
    "programs",
    "clipboard:read",
    "secrets"
  ],
