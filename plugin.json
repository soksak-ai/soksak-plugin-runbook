{
  "spec": "soksak-spec-plugin@0.0.1",
  "id": "soksak-plugin-runbook",
  "name": {
    "ko": "런북",
    "en": "Runbook"
  },
  "version": "0.0.1",
  "repo": "https://github.com/soksak-ai/soksak-plugin-runbook.git",
  "description": "재사용 가능한 작업(런북)을 저장하고 실행한다. 작업은 파라미터·환경변수·시크릿·다른 작업 출력을 Reference 로 엮으며, 링킹은 순수 해석 + 의존 그래프 + 순환 검출로 안전하게 풀린다.",
  "entry": "main.js",
  "permissions": [
    "data",
    "commands",
    "ui",
    "process",
    "network",
    "notify",
    "programs",
    "clipboard:read",
    "secrets"
  ],
  "contributes": {
    "commands": [
      {
        "name": "runbook.command.add",
        "title": "명령 추가"
      },
      {
        "name": "runbook.command.get",
        "title": "명령 조회"
      },
      {
        "name": "runbook.command.refs",
        "title": "명령 Reference 추출"
      },
      {
        "name": "runbook.command.update",
        "title": "명령 갱신"
      },
      {
        "name": "runbook.command.delete",
        "title": "명령 삭제(소프트)"
      },
      {
        "name": "runbook.command.restore",
        "title": "명령 복원"
      },
      {
        "name": "runbook.command.duplicate",
        "title": "명령 복제"
      },
      {
        "name": "runbook.command.list",
        "title": "명령 목록"
      },
      {
        "name": "runbook.command.search",
        "title": "명령 검색"
      },
      {
        "name": "runbook.command.set-group",
        "title": "명령 그룹 이동"
      },
      {
        "name": "runbook.command.favorite",
        "title": "명령 즐겨찾기 토글"
      },
      {
        "name": "runbook.group.add",
        "title": "그룹 추가"
      },
      {
        "name": "runbook.group.update",
        "title": "그룹 갱신"
      },
      {
        "name": "runbook.group.delete",
        "title": "그룹 삭제"
      },
      {
        "name": "runbook.group.list",
        "title": "그룹 목록"
      },
      {
        "name": "runbook.history.add",
        "title": "히스토리 기록"
      },
      {
        "name": "runbook.history.list",
        "title": "히스토리 목록"
      },
      {
        "name": "runbook.history.search",
        "title": "히스토리 검색"
      },
      {
        "name": "runbook.history.delete",
        "title": "히스토리 삭제(소프트)"
      },
      {
        "name": "runbook.history.restore",
        "title": "히스토리 복원"
      },
      {
        "name": "runbook.history.clear",
        "title": "히스토리 전체 삭제"
      },
      {
        "name": "runbook.export",
        "title": "런북 내보내기(JSONL)"
      },
      {
        "name": "runbook.import",
        "title": "런북 가져오기(JSONL)"
      },
      {
        "name": "ref.parse",
        "title": "Reference 파싱(엔진 검증)"
      },
      {
        "name": "ref.resolve",
        "title": "Reference 해석(엔진 검증)"
      }
    ]
  }
}
